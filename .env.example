# Supabase — PUBLIC anon key only.
# Per the approved Technical Architecture, this project never uses the
# Supabase service role key anywhere. All access control is enforced
# through Row Level Security (Owner) and application-layer scoping
# (Driver). Do not add SUPABASE_SERVICE_ROLE_KEY to this project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App timezone — used by src/utils/date.ts for all "today" boundaries
# and display formatting. Should stay Asia/Jakarta per project scope.
NEXT_PUBLIC_APP_TIMEZONE=Asia/Jakarta

# --- Reserved for Milestone 2 (Authentication) — not used yet ---
# Secret used to sign the Driver app-layer session cookie (PIN login
# does not use Supabase Auth — see TECHNICAL_ARCHITECTURE.md Section 5).
# Generate with: openssl rand -base64 32
# DRIVER_SESSION_SECRET=

# --- Reserved for Milestone 4 (Delivery Management) — not used yet ---
# Google Maps (geocoding, driver navigation deep links)
# GOOGLE_MAPS_API_KEY=
# Gemini (route-sequencing assist — not route optimization)
# GEMINI_API_KEY=
